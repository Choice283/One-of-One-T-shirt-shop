# Hosted Postgres connection string (Vercel Postgres, Neon, Supabase, etc.)
# Get this from your database provider once it's provisioned.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Vercel Blob storage token — created automatically when you attach a Blob
# store to your Vercel project (Storage tab -> Create Database -> Blob).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Stripe (get from https://dashboard.stripe.com/apikeys — use sk_test_ while
# testing, sk_live_ once you're ready to take real payments)
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Base URL of your site (used for Stripe redirect + webhook)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Admin login (Basic Auth on /admin/*)
ADMIN_USER="choice"
ADMIN_PASS="change-me"

# Flat shipping rates in cents
SHIPPING_STANDARD_CENTS=599
SHIPPING_EXPRESS_CENTS=1499
