# Hosted Postgres connection string (Vercel Postgres, Neon, Supabase, etc.)
# Get this from your database provider once it's provisioned.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Vercel Blob storage token — created automatically when you attach a Blob
# store to your Vercel project (Storage tab -> Create Database -> Blob).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Stripe (get from https://dashboard.stripe.com/apikeys — use sk_test_ while
# testing, sk_live_ once you're ready to take real payments)
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Base URL of your site (used for Stripe redirect + webhook)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Admin login (Basic Auth on /admin/*)
ADMIN_USER="choice"
ADMIN_PASS="change-me"

# Uber Direct (get these from https://direct.uber.com -> Developer tab.
# Start with Test mode credentials — they don't dispatch real couriers.)
UBER_CLIENT_ID="xxx"
UBER_CLIENT_SECRET="xxx"
UBER_CUSTOMER_ID="xxx"

# Flat local-courier fee charged to the buyer at checkout, in cents. The
# real Uber Direct quote is fetched after payment (see app/api/webhook) —
# this is just what the buyer pays up front.
UBER_DELIVERY_FLAT_CENTS=899

# Your store's pickup address — where Uber Direct couriers pick up shirts
# from. This is a single fixed address, not per-listing.
STORE_PICKUP_NAME="One-of-a-Kind Tees"
STORE_PICKUP_STREET="123 Main St"
STORE_PICKUP_CITY="New York"
STORE_PICKUP_STATE="NY"
STORE_PICKUP_ZIP="10001"
STORE_PICKUP_COUNTRY="US"
STORE_PICKUP_PHONE="+15555555555"
